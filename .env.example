# ================================================================
#  .env.example — Copy this to .env and fill in your values
#
#  NEVER commit .env to git. Add it to .gitignore.
# ================================================================

# ── MongoDB Atlas ────────────────────────────────────────────────
# Get this from: Atlas → Connect → Connect your application
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/venturehub?retryWrites=true&w=majority

# ── Server ───────────────────────────────────────────────────────
PORT=3000

# ── App ──────────────────────────────────────────────────────────
NODE_ENV=development
